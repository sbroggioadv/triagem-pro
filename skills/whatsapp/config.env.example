# Configuracao da API Zappfy
# ATENCAO: arquivo sensivel, nao commitar. .gitignore cobre este path.
# Copie este arquivo para config.env e preencha com seu token real.

# Token da instancia (credencial de API) — obtenha em https://dash.zappfy.io
ZAPPFY_TOKEN=seu-token-aqui

# Numero conectado (WhatsApp Business)
# ZAPPFY_PHONE_NUMBER=5511999999999

# URL base da API
# Default: zappfy-v2.uazapi.com (endpoint tecnico uazapi)
# Alternativo: app.zappfy.com.br (dominio oficial Zappfy)
ZAPPFY_BASE_URL=https://zappfy-v2.uazapi.com

# Transcricao de audios via Whisper (opcional)
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cpu
